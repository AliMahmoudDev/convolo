!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
.next/
out/

# Production
build/
dist/

# Testing
coverage/
.nyc_output/

# ===========================
# Environment & Secrets
# ===========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ===========================
# IDE & Editor
# ===========================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ===========================
# OS Generated
# ===========================
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# ===========================
